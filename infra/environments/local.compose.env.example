MYSQL_ENV_FILE=mysql/.env.local
CANARY_ENV_FILE=canary/.env.local
OTSERVER_WEB_ENV_FILE=otserver-web/.env.local

# Fork: ghcr.io/rodviana/canary:rodrigo (workflow docker-publish-branch no submódulo canary). Upstream: opentibiabr/canary:latest
CANARY_IMAGE=ghcr.io/rodviana/canary:rodrigo
# Build --canary-local: label na imagem (fonte = checkout em canary/). Padrão rodrigo.
CANARY_GIT_BRANCH=rodrigo

MYSQL_PUBLISH_ADDRESS=127.0.0.1
MYSQL_PUBLISH_PORT=3306

OT_SERVER_LOGIN_PORT=7171
OT_SERVER_GAME_PORT=7172
OT_SERVER_STATUS_PORT=7171
GAME_PUBLISH_ADDRESS=127.0.0.1

API_PUBLISH_ADDRESS=127.0.0.1
API_PUBLISH_PORT=8080

SITE_PUBLISH_ADDRESS=127.0.0.1
SITE_HTTP_PORT=8081

VITE_API_URL=/api
