# Copiar para .env. Requer rede Docker ot-mysql-net (infra/mysql).

# --- MySQL (host = serviço "database" na rede ot-mysql-net) ---
MYSQL_URL=jdbc:mysql://database:3306/otservbr-global?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
MYSQL_USER=canary
MYSQL_PASSWORD=change-me-canary

# --- JWT (produção: string longa e aleatória) ---
OT_JWT_SECRET=change-me-min-32-chars-random-secret-please

# --- Resposta de login / mundo (endereço/porta que o cliente OT usa ao entrar no personagem) ---
# Deve coincidir com OT_SERVER_IP / OT_SERVER_GAME_PORT no Canary (.env em infra/canary).
# Se OT_GAMESERVER_PORT ≠ gameProtocolPort ou o SG não tiver TCP nessa porta, o login pode funcionar e falhar ao escolher char.
OT_GAMESERVER_IP=54.207.99.210
OT_GAMESERVER_PORT=7172
OT_GAMESERVER_NAME=OTServBR-Global

# Cloudflare (proxy laranja) ou outro reverse proxy à frente da API: true
OT_SECURITY_TRUSTFORWARDHEADERS=true

# --- Site: URL da API no bundle JS (/api = mesmo host, ex. https://meuotserver.com.br/api) ---
VITE_API_URL=/api

# --- Portas no host ---
SITE_HTTP_PORT=80
SITE_PUBLISH_ADDRESS=0.0.0.0

# API também no host (ex. cliente/login direto); 127.0.0.1 = só local
API_PUBLISH_PORT=8080
API_PUBLISH_ADDRESS=127.0.0.1
