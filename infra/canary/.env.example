# Imagem pré-construída (pull). Para build local ver docker-compose.build.yml.
CANARY_IMAGE=ghcr.io/opentibiabr/canary:latest

# --- MySQL (mesmo utilizador/base que infra/mysql; host = nome do serviço na rede ot-mysql-net) ---
OT_DB_HOST=database
OT_DB_PORT=3306
OT_DB_USER=canary
OT_DB_PASSWORD=change-me-canary
OT_DB_DATABASE=otservbr-global

# Endereço anunciado ao cliente Tibia: IP público da EC2 ou subdomínio DNS-only.
# NÃO uses 127.0.0.1 nem um host proxied por Cloudflare para as portas 7171/7172.
OT_SERVER_IP=54.207.99.210

OT_SERVER_LOGIN_PORT=7171
OT_SERVER_GAME_PORT=7172
OT_SERVER_STATUS_PORT=7171

OT_SERVER_DATA=data-otservbr-global
OT_SERVER_TEST_ACCOUNTS=false

# --- XP / rates (opcional; aplicados em config.lua no arranque do contentor) ---
# Com rateUseStages=false (defeito), só rateExp conta. Com true, vê data/stages.lua (mount canary/data).
# OT_RATE_EXP=50
# OT_RATE_USE_STAGES=true

# Bind das portas de jogo no host (0.0.0.0 na EC2; 127.0.0.1 só para testes locais).
GAME_PUBLISH_ADDRESS=0.0.0.0

# --- Build opcional (docker-compose.build.yml) ---
# VCPKG_FEED_URL=https://nuget.pkg.github.com/SEU_USER/index.json
# VCPKG_FEED_USERNAME=SEU_USER
# GITHUB_TOKEN_FILE=./secrets/github_token.txt
