# Imagem pré-construída (pull). Para binário + config.lua do teu submódulo: ./infra/up.sh --canary-local
# Submódulo canary: branch padrão rodrigo (.gitmodules no repo pai). Opcional no build: CANARY_GIT_BRANCH=rodrigo
#
# Fork rodviana/canary: após push na branch rodrigo, o workflow docker-publish-branch.yml publica no GHCR.
# Produção EC2 (sem build na máquina): CANARY_IMAGE=ghcr.io/rodviana/canary:rodrigo
# (se o pacote GHCR for privado, faz docker login ghcr.io na EC2 ou torna o pacote público nas definições do GitHub.)
CANARY_IMAGE=ghcr.io/rodviana/canary:rodrigo
# Com --canary-local (overlay infra/docker-compose.canary-local.yml) usa-se a imagem de build:
# CANARY_LOCAL_IMAGE=ot-stack-canary:local
# Mac ARM / build ARM: CANARY_DOCKERFILE=Dockerfile.arm

# --- MySQL (mesmo utilizador/base que infra/mysql; host = nome do serviço na rede ot-mysql-net) ---
OT_DB_HOST=database
OT_DB_PORT=3306
OT_DB_USER=canary
OT_DB_PASSWORD=change-me-canary
OT_DB_DATABASE=otservbr-global

# Endereço anunciado ao cliente Tibia: IP público da EC2 ou subdomínio DNS-only.
# NÃO uses 127.0.0.1 nem um host proxied por Cloudflare para as portas 7171/7172.
# Na EC2, o security group tem de permitir TCP em OT_SERVER_LOGIN_PORT e OT_SERVER_GAME_PORT (login vs entrada no mundo).
OT_SERVER_IP=54.207.99.210

OT_SERVER_LOGIN_PORT=7171
OT_SERVER_GAME_PORT=7172
OT_SERVER_STATUS_PORT=7171

# Deve coincidir com dataPackDirectory em canary/config.lua (datapack oficial Global).
OT_SERVER_DATA=data-otservbr-global
# Mapa global principal (mesmo asset que mapDownloadUrl em canary/config.lua). NÃO uses o .otbm de world/custom como principal.
OT_SERVER_MAP=https://github.com/rodviana/canary/releases/download/teste/otservbr.otbm
# Se já tens world/otservbr.otbm errado (ex. antigo download custom), pões 1 uma vez para apagar e voltar a descarregar.
OT_SERVER_MAP_FORCE=false
OT_SERVER_TEST_ACCOUNTS=false

# Bind das portas de jogo no host (0.0.0.0 na EC2; 127.0.0.1 só para testes locais).
GAME_PUBLISH_ADDRESS=0.0.0.0

# --- Build opcional (docker-compose.build.yml / --canary-local) ---
# Token opcional: acelera vcpkg via NuGet; sem ficheiro, compila tudo a partir do código.
# VCPKG_FEED_URL=https://nuget.pkg.github.com/SEU_USER/index.json
# VCPKG_FEED_USERNAME=SEU_USER
# GITHUB_TOKEN_FILE=./secrets/github_token.txt
