# Copiar para .env e definir passwords fortes em produção.
# O entrypoint MariaDB cria automaticamente:
#   - base MYSQL_DATABASE
#   - utilizador MYSQL_USER com permissões nessa base (Canary + ot-login-api)

MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_DATABASE=otservbr-global
MYSQL_USER=canary
MYSQL_PASSWORD=change-me-canary

# Porta no HOST (dentro do contentor é sempre 3306).
MYSQL_PUBLISH_PORT=3306

# Bind no host: 127.0.0.1 = só máquina local (recomendado na EC2 com app no host).
# Para outra instância na mesma VPC aceder ao MySQL: 0.0.0.0 + SG a restringir origem.
MYSQL_PUBLISH_ADDRESS=127.0.0.1

# --- Canary (config.lua / env) ---
# mysqlHost = IP da EC2 ou "database" se Canary estiver na rede Docker ot-mysql-net
# mysqlUser / mysqlPass / mysqlDatabase = valores acima
# mysqlPort = 3306 (ou MYSQL_PUBLISH_PORT se ligares ao host)

# --- ot-login-api (Spring) ---
# MYSQL_URL=jdbc:mysql://database:3306/otservbr-global?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
#   (use "database" como host se o JAR estiver no compose com rede ot-mysql-net)
# MYSQL_USER / MYSQL_PASSWORD = iguais a MYSQL_USER / MYSQL_PASSWORD deste ficheiro
